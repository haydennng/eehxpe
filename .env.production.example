# eehxpe Production Environment Variables
# Copy this to .env.production and fill in real values
# NEVER commit .env.production to git!

# Flask Configuration
FLASK_ENV=production
FLASK_SECRET_KEY=GENERATE_A_STRONG_SECRET_KEY_HERE

# Badminton App Configuration
BADMINTON_DATA_DIR=C:\Users\Hayde\eehxpe\data\badminton
LOG_DIR=C:\Users\Hayde\eehxpe\logs\badminton

# Session Configuration (for subpath deployment)
SESSION_COOKIE_PATH=/badminton
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Future: Database connection strings, API keys, etc.
# DATABASE_URL=sqlite:///C:/Users/Hayde/eehxpe/data/eehxpe.db
